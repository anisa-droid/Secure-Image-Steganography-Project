#  Fixes made after first prototype presentation: Native file dialog via OS APIs 
def _native_open(title, filetypes, parent=None):
    if sys.platform == "win32":
        import ctypes
        from ctypes import wintypes
        filter_parts = []
        for label, pattern in filetypes:
            exts = pattern.replace(" ", ";")
            filter_parts.append(f"{label}\0{exts}\0")
        filter_str = "".join(filter_parts) + "\0"

        class OPENFILENAMEW(ctypes.Structure):
            _fields_ = [
                ("lStructSize",       ctypes.c_uint32),
                ("hwndOwner",         wintypes.HWND),
                ("hInstance",         wintypes.HINSTANCE),
                ("lpstrFilter",       wintypes.LPCWSTR),
                ("lpstrCustomFilter", wintypes.LPWSTR),
                ("nMaxCustFilter",    ctypes.c_uint32),
                ("nFilterIndex",      ctypes.c_uint32),
                ("lpstrFile",         wintypes.LPWSTR),
                ("nMaxFile",          ctypes.c_uint32),
                ("lpstrFileTitle",    wintypes.LPWSTR),
                ("nMaxFileTitle",     ctypes.c_uint32),
                ("lpstrInitialDir",   wintypes.LPCWSTR),
                ("lpstrTitle",        wintypes.LPCWSTR),
                ("Flags",             ctypes.c_uint32),
                ("nFileOffset",       ctypes.c_uint16),
                ("nFileExtension",    ctypes.c_uint16),
                ("lpstrDefExt",       wintypes.LPCWSTR),
                ("lCustData",         ctypes.c_lpvoid),
                ("lpfnHook",          ctypes.c_void_p),
                ("lpTemplateName",    wintypes.LPCWSTR),
                ("pvReserved",        ctypes.c_void_p),
                ("dwReserved",        ctypes.c_uint32),
                ("FlagsEx",           ctypes.c_uint32),
            ]

        buf = ctypes.create_unicode_buffer(32768)
        ofn = OPENFILENAMEW()
        ofn.lStructSize  = ctypes.sizeof(OPENFILENAMEW)
        ofn.hwndOwner    = int(parent.winfo_id()) if parent else 0
        ofn.lpstrFilter  = filter_str
        ofn.nFilterIndex = 1
        ofn.lpstrFile    = buf
        ofn.nMaxFile     = len(buf)
        ofn.lpstrTitle   = title
        ofn.Flags        = 0x00000800 | 0x00001000
        if ctypes.windll.comdlg32.GetOpenFileNameW(ctypes.byref(ofn)):
            return buf.value
        return ""

    elif sys.platform == "darwin":
        ext_list = []
        for _, pattern in filetypes:
            for p in pattern.split():
                ext = p.lstrip("*.")
                if ext and ext != "*":
                    ext_list.append(f'"{ext}"')
        ext_clause = f"of type {{{', '.join(ext_list)}}}" if ext_list else ""
        script = f'POSIX path of (choose file with prompt "{title}" {ext_clause})'
        try:
            result = subprocess.run(["osascript", "-e", script],
                                    capture_output=True, text=True, timeout=60)
            return result.stdout.strip()
        except Exception:
            return ""

    else:
        filter_flags = []
        for label, pattern in filetypes:
            if pattern.strip() not in ("*.*", "*"):
                filter_flags += ["--file-filter", f"{label} | {pattern}"]
        try:
            result = subprocess.run(
                ["zenity", "--file-selection", f"--title={title}"] + filter_flags,
                capture_output=True, text=True, timeout=60)
            if result.returncode == 0:
                return result.stdout.strip()
        except FileNotFoundError:
            pass
        try:
            mime_filter = "Images (*.png *.jpg *.bmp *.jpeg)|*.png *.jpg *.bmp *.jpeg"
            result = subprocess.run(
                ["kdialog", "--getopenfilename", os.path.expanduser("~"),
                 mime_filter, "--title", title],
                capture_output=True, text=True, timeout=60)
            if result.returncode == 0:
                return result.stdout.strip()
        except FileNotFoundError:
            pass
        return filedialog.askopenfilename(title=title,
                                          filetypes=filetypes + [("All Files", "*.*")])


def _native_save(title, default_name, parent=None):
    if sys.platform == "win32":
        import ctypes
        from ctypes import wintypes
        filter_str = "PNG Image\0*.png\0BMP Image\0*.bmp\0All Files\0*.*\0\0"

        class OPENFILENAMEW(ctypes.Structure):
            _fields_ = [
                ("lStructSize",       ctypes.c_uint32),
                ("hwndOwner",         wintypes.HWND),
                ("hInstance",         wintypes.HINSTANCE),
                ("lpstrFilter",       wintypes.LPCWSTR),
                ("lpstrCustomFilter", wintypes.LPWSTR),
                ("nMaxCustFilter",    ctypes.c_uint32),
                ("nFilterIndex",      ctypes.c_uint32),
                ("lpstrFile",         wintypes.LPWSTR),
                ("nMaxFile",          ctypes.c_uint32),
                ("lpstrFileTitle",    wintypes.LPWSTR),
                ("nMaxFileTitle",     ctypes.c_uint32),
                ("lpstrInitialDir",   wintypes.LPCWSTR),
                ("lpstrTitle",        wintypes.LPCWSTR),
                ("Flags",             ctypes.c_uint32),
                ("nFileOffset",       ctypes.c_uint16),
                ("nFileExtension",    ctypes.c_uint16),
                ("lpstrDefExt",       wintypes.LPCWSTR),
                ("lCustData",         ctypes.c_lpvoid),
                ("lpfnHook",          ctypes.c_void_p),
                ("lpTemplateName",    wintypes.LPCWSTR),
                ("pvReserved",        ctypes.c_void_p),
                ("dwReserved",        ctypes.c_uint32),
                ("FlagsEx",           ctypes.c_uint32),
            ]

        buf = ctypes.create_unicode_buffer(default_name, 32768)
        ofn = OPENFILENAMEW()
        ofn.lStructSize  = ctypes.sizeof(OPENFILENAMEW)
        ofn.hwndOwner    = int(parent.winfo_id()) if parent else 0
        ofn.lpstrFilter  = filter_str
        ofn.nFilterIndex = 1
        ofn.lpstrFile    = buf
        ofn.nMaxFile     = len(buf)
        ofn.lpstrTitle   = title
        ofn.lpstrDefExt  = "png"
        ofn.Flags        = 0x00000800 | 0x00000002
        if ctypes.windll.comdlg32.GetSaveFileNameW(ctypes.byref(ofn)):
            return buf.value
        return ""

    elif sys.platform == "darwin":
        script = (f'POSIX path of (choose file name with prompt "{title}" '
                  f'default name "{default_name}")')
        try:
            result = subprocess.run(["osascript", "-e", script],
                                    capture_output=True, text=True, timeout=60)
            path = result.stdout.strip()
            if path and not path.lower().endswith((".png", ".bmp")):
                path += ".png"
            return path
        except Exception:
            return ""

    else:
        try:
            result = subprocess.run(
                ["zenity", "--file-selection", "--save",
                 f"--title={title}", f"--filename={default_name}",
                 "--confirm-overwrite",
                 "--file-filter", "PNG / BMP | *.png *.bmp"],
                capture_output=True, text=True, timeout=60)
            if result.returncode == 0:
                path = result.stdout.strip()
                if path and not path.lower().endswith((".png", ".bmp")):
                    path += ".png"
                return path
        except FileNotFoundError:
            pass
        try:
            result = subprocess.run(
                ["kdialog", "--getsavefilename",
                 os.path.join(os.path.expanduser("~"), default_name),
                 "*.png *.bmp", "--title", title],
                capture_output=True, text=True, timeout=60)
            if result.returncode == 0:
                path = result.stdout.strip()
                if path and not path.lower().endswith((".png", ".bmp")):
                    path += ".png"
                return path
        except FileNotFoundError:
            pass
        return filedialog.asksaveasfilename(
            title=title, defaultextension=".png",
            filetypes=[("PNG Image", "*.png"), ("BMP Image", "*.bmp")],
            initialfile=default_name)



