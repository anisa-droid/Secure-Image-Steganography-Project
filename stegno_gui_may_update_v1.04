# ═══════════════════════════════════════════════════════════════════════════════
#  PLATFORM HELPERS
# ═══════════════════════════════════════════════════════════════════════════════

def _is_win():   return sys.platform == "win32"
def _is_mac():   return sys.platform == "darwin"
def _is_linux(): return sys.platform.startswith("linux")


def _ps_run(cmd):
    """Run a PowerShell command silently. Returns stdout string."""
    try:
        r = subprocess.run(
            ["powershell", "-NoProfile", "-NonInteractive",
             "-WindowStyle", "Hidden", "-Command", cmd],
            capture_output=True, text=True, timeout=120,
            creationflags=0x08000000)          # CREATE_NO_WINDOW
        lines = [l for l in r.stdout.strip().splitlines() if l.strip()]
        return lines[-1] if lines else ""
    except Exception:
        return ""


# ── Native open-file dialog ───────────────────────────────────────────────────

def _native_open(title, parent=None):
    """Open-file dialog that returns a path string or ''."""
    if _is_win():
        cmd = (
            "Add-Type -AssemblyName System.Windows.Forms; "
            "$d = New-Object System.Windows.Forms.OpenFileDialog; "
            f"$d.Title = '{title}'; "
            "$d.Filter = 'Images|*.png;*.jpg;*.bmp;*.jpeg|All Files|*.*'; "
            "$d.CheckFileExists = $true; "
            "if ($d.ShowDialog() -eq [System.Windows.Forms.DialogResult]::OK) "
            "{ Write-Output $d.FileName }"
        )
        p = _ps_run(cmd)
        return p if p else ""

    elif _is_mac():
        script = f'POSIX path of (choose file with prompt "{title}" of type {{"png","jpg","jpeg","bmp"}})'
        try:
            r = subprocess.run(["osascript", "-e", script],
                               capture_output=True, text=True, timeout=60)
            return r.stdout.strip()
        except Exception:
            return ""

    else:  # Linux
        for tool, args in [
            ("zenity", ["zenity", "--file-selection",
                        f"--title={title}",
                        "--file-filter=Images | *.png *.jpg *.bmp *.jpeg"]),
            ("kdialog", ["kdialog", "--getopenfilename",
                         os.path.expanduser("~"),
                         "*.png *.jpg *.bmp *.jpeg",
                         "--title", title]),
        ]:
            try:
                r = subprocess.run(args, capture_output=True, text=True, timeout=60)
                if r.returncode == 0 and r.stdout.strip():
                    return r.stdout.strip()
            except FileNotFoundError:
                continue
        return filedialog.askopenfilename(
            title=title,
            filetypes=[("Images", "*.png *.jpg *.bmp *.jpeg"), ("All Files", "*.*")])


# ── Native save-image dialog ──────────────────────────────────────────────────

def _native_save_img(title, default_name, parent=None):
    """Save-file dialog for PNG/BMP. Returns path or ''."""
    if _is_win():
        cmd = (
            "Add-Type -AssemblyName System.Windows.Forms; "
            "$d = New-Object System.Windows.Forms.SaveFileDialog; "
            f"$d.Title = '{title}'; "
            "$d.Filter = 'PNG Image|*.png|BMP Image|*.bmp|All Files|*.*'; "
            f"$d.FileName = '{default_name}'; "
            "$d.DefaultExt = 'png'; "
            "$d.OverwritePrompt = $true; "
            "if ($d.ShowDialog() -eq [System.Windows.Forms.DialogResult]::OK) "
            "{ Write-Output $d.FileName }"
        )
        p = _ps_run(cmd)
        return p if p else ""

    elif _is_mac():
        script = (f'POSIX path of (choose file name with prompt "{title}" ' +
                  f'default name "{default_name}")')
        try:
            r = subprocess.run(["osascript", "-e", script],
                               capture_output=True, text=True, timeout=60)
            p = r.stdout.strip()
            if p and not p.lower().endswith((".png", ".bmp")):
                p += ".png"
            return p
        except Exception:
            return ""

    else:
        for tool, args in [
            ("zenity", ["zenity", "--file-selection", "--save",
                        f"--title={title}",
                        f"--filename={os.path.join(os.path.expanduser('~'), default_name)}",
                        "--confirm-overwrite",
                        "--file-filter=PNG / BMP | *.png *.bmp"]),
            ("kdialog", ["kdialog", "--getsavefilename",
                         os.path.join(os.path.expanduser("~"), default_name),
                         "*.png *.bmp", "--title", title]),
        ]:
            try:
                r = subprocess.run(args, capture_output=True, text=True, timeout=60)
                if r.returncode == 0 and r.stdout.strip():
                    p = r.stdout.strip()
                    if not p.lower().endswith((".png", ".bmp")):
                        p += ".png"
                    return p
            except FileNotFoundError:
                continue
        return filedialog.asksaveasfilename(
            title=title, defaultextension=".png",
            filetypes=[("PNG Image", "*.png"), ("BMP Image", "*.bmp")],
            initialfile=default_name)


# ── Native save-text dialog ───────────────────────────────────────────────────

def _native_save_txt(title, default_name, parent=None):
    """Save-file dialog for .txt. Returns path or ''."""
    if _is_win():
        cmd = (
            "Add-Type -AssemblyName System.Windows.Forms; "
            "$d = New-Object System.Windows.Forms.SaveFileDialog; "
            f"$d.Title = '{title}'; "
            "$d.Filter = 'Text File|*.txt|All Files|*.*'; "
            f"$d.FileName = '{default_name}'; "
            "$d.DefaultExt = 'txt'; "
            "$d.OverwritePrompt = $true; "
            "if ($d.ShowDialog() -eq [System.Windows.Forms.DialogResult]::OK) "
            "{ Write-Output $d.FileName }"
        )
        p = _ps_run(cmd)
        return p if p else ""

    elif _is_mac():
        script = (f'POSIX path of (choose file name with prompt "{title}" ' +
                  f'default name "{default_name}")')
        try:
            r = subprocess.run(["osascript", "-e", script],
                               capture_output=True, text=True, timeout=60)
            p = r.stdout.strip()
            if p and not p.lower().endswith(".txt"):
                p += ".txt"
            return p
        except Exception:
            return ""

    else:
        for tool, args in [
            ("zenity", ["zenity", "--file-selection", "--save",
                        f"--title={title}",
                        f"--filename={os.path.join(os.path.expanduser('~'), default_name)}",
                        "--confirm-overwrite",
                        "--file-filter=Text File | *.txt"]),
            ("kdialog", ["kdialog", "--getsavefilename",
                         os.path.join(os.path.expanduser("~"), default_name),
                         "*.txt", "--title", title]),
        ]:
            try:
                r = subprocess.run(args, capture_output=True, text=True, timeout=60)
                if r.returncode == 0 and r.stdout.strip():
                    p = r.stdout.strip()
                    if not p.lower().endswith(".txt"):
                        p += ".txt"
                    return p
            except FileNotFoundError:
                continue
        return filedialog.asksaveasfilename(
            title=title, defaultextension=".txt",
            filetypes=[("Text File", "*.txt")],
            initialfile=default_name)


# ── Native notification ───────────────────────────────────────────────────────

def _native_notify(title, message, parent=None):
    """Show a native OS success dialog/notification."""
    if _is_win():
        try:
            import ctypes
            hwnd = int(parent.winfo_id()) if parent else 0
            ctypes.windll.user32.MessageBoxW(
                hwnd, message, title, 0x00000040 | 0x00010000)
            return
        except Exception:
            pass

    elif _is_mac():
        safe_msg   = message.replace('"', '\\\"'  )
        safe_title = title.replace('"', '\\\"'  )
        script = (f'display dialog "{safe_msg}" with title "{safe_title}" ' +
                  'buttons {"OK"} default button "OK" with icon note')
        try:
            subprocess.run(["osascript", "-e", script],
                           capture_output=True, timeout=30)
            return
        except Exception:
            pass

    else:
        for args in [
            ["notify-send", "--app-name=STEGO", "--icon=dialog-information",
             title, message],
            ["zenity", "--info", f"--title={title}", f"--text={message}"],
            ["kdialog", "--title", title, "--msgbox", message],
        ]:
            try:
                if args[0] == "notify-send":
                    subprocess.Popen(args)
                else:
                    subprocess.run(args, capture_output=True, timeout=30)
                return
            except FileNotFoundError:
                continue

    messagebox.showinfo(title, message)


# ── Native share ──────────────────────────────────────────────────────────────

def _native_share_file(filepath, parent=None):
    """Share a file via OS-native mechanisms."""
    if not filepath or not os.path.isfile(filepath):
        messagebox.showerror("Share", "File not found — save it first.")
        return

    if _is_win():
        # Win10/11 Share UI via WinRT through PowerShell
        safe = filepath.replace("\\", "\\\\").replace("'", "")
        cmd = (
            "Add-Type -AssemblyName System.Runtime.WindowsRuntime; "
            "[void][Windows.ApplicationModel.DataTransfer.DataTransferManager,"
            "Windows.ApplicationModel.DataTransfer,ContentType=WindowsRuntime]; "
            "[void][Windows.Storage.StorageFile,Windows.Storage,ContentType=WindowsRuntime]; "
            f"$f = [Windows.Storage.StorageFile]::GetFileFromPathAsync('{safe}').GetAwaiter().GetResult(); "
            "$dtm=[Windows.ApplicationModel.DataTransfer.DataTransferManager]::GetForCurrentView(); "
            "$dtm.add_DataRequested({"
            "param($s,$e); "
            "$e.Request.Data.SetStorageItems("
            "[System.Collections.Generic.List[Windows.Storage.IStorageItem]]@($f)); "
            "$e.Request.Data.Properties.Title='Share STEGO Image'}); "
            "[Windows.ApplicationModel.DataTransfer.DataTransferManager]::ShowShareUI()"
        )
        try:
            subprocess.Popen(["powershell", "-NoProfile", "-NonInteractive",
                              "-WindowStyle", "Hidden", "-Command", cmd],
                             creationflags=0x08000000)
            return
        except Exception:
            pass
        try:
            subprocess.Popen(["explorer", "/select,", filepath])
        except Exception:
            pass
        return

    elif _is_mac():
        script = f'tell application "Finder" to open POSIX file "{filepath}"'
        subprocess.Popen(["osascript", "-e", script])
        return

    else:  # Linux
        for args in [
            ["xdg-email", f"--attach={filepath}"],
            ["thunderbird", "--compose", f"attachment='{filepath}'"],
            ["xdg-open", os.path.dirname(filepath)],
        ]:
            try:
                subprocess.Popen(args)
                return
            except FileNotFoundError:
                continue
        messagebox.showinfo("Share", f"Image saved at:\n{filepath}\n\nShare it manually.")


def _native_share_text(text, parent=None):
    """Copy key to clipboard and try to open a share/email target."""
    try:
        if parent:
            parent.clipboard_clear()
            parent.clipboard_append(text)
    except Exception:
        pass

    if _is_win():
        # Copy via PowerShell then try Share UI
        safe_text = text.replace("'", "''")
        cmd = (
            "Add-Type -AssemblyName System.Windows.Forms; "
            f"[System.Windows.Forms.Clipboard]::SetText('{safe_text}'); "
            "Add-Type -AssemblyName System.Runtime.WindowsRuntime; "
            "[void][Windows.ApplicationModel.DataTransfer.DataTransferManager,"
            "Windows.ApplicationModel.DataTransfer,ContentType=WindowsRuntime]; "
            "$dtm=[Windows.ApplicationModel.DataTransfer.DataTransferManager]::GetForCurrentView(); "
            f"$dtm.add_DataRequested({{param($s,$e); $e.Request.Data.SetText('{safe_text}'); "
            "$e.Request.Data.Properties.Title='STEGO Decryption Key'}); "
            "[Windows.ApplicationModel.DataTransfer.DataTransferManager]::ShowShareUI()"
        )
        try:
            subprocess.Popen(["powershell", "-NoProfile", "-NonInteractive",
                              "-WindowStyle", "Hidden", "-Command", cmd],
                             creationflags=0x08000000)
            return
        except Exception:
            pass
        messagebox.showinfo("Key Copied",
            "Key copied to clipboard. Paste it in your messaging app.")
        return

    elif _is_mac():
        safe = text.replace('"', '\\\"'  )
        subprocess.Popen(["osascript", "-e", f'set the clipboard to "{safe}"'])
        return

    else:  # Linux
        for args in [
            ["xdg-email", f"--body={text}"],
        ]:
            try:
                subprocess.Popen(args)
                return
            except FileNotFoundError:
                continue
        messagebox.showinfo("Key Copied",
            "Key copied to clipboard. Paste it into your preferred app.")


# ═══════════════════════════════════════════════════════════════════════════════
#  CRYPTO + LSB STEGANOGRAPHY ENGINE
# ═══════════════════════════════════════════════════════════════════════════════

SALT_BYTES      = 16     # 128-bit random salt — IS the user-facing key token
PBKDF2_ITER     = 100_000

def _derive_key(salt: bytes) -> bytes:
    """PBKDF2-HMAC-SHA256(salt, salt, 100k) → Fernet-ready URL-safe b64 key."""
    kdf = PBKDF2HMAC(algorithm=hashes.SHA256(), length=32, salt=salt,
                     iterations=PBKDF2_ITER, backend=default_backend())
    return base64.urlsafe_b64encode(kdf.derive(salt))


def _scatter_indices(n_pixels: int, n_needed: int, salt: bytes) -> np.ndarray:
    """
    Prefix-stable pseudorandom unique pixel indices seeded by salt.
    Uses argsort of uniform floats — same seed always produces the same
    first k indices regardless of how many total we request (prefix-stable).
    O(n_pixels log n_pixels) but fully vectorised via numpy.
    """
    seed = int.from_bytes(hashlib.sha256(salt + b"scatter").digest()[:8], "big")
    rng  = np.random.default_rng(seed)
    floats = rng.random(n_pixels)
    if n_needed < n_pixels:
        part  = np.argpartition(floats, n_needed)[:n_needed]
        order = np.argsort(floats[part])
        return part[order].astype(np.int64)
    return np.argsort(floats).astype(np.int64)


def _embed_bits(img_flat: np.ndarray, payload: bytes, salt: bytes) -> None:
    """Embed payload into img_flat (H*W, 3) using 2 LSBs of blue channel per pixel."""
    indices = _scatter_indices(len(img_flat), len(payload) * 4, salt)
    bits = []
    for byte in payload:
        for shift in range(7, -1, -1):
            bits.append((byte >> shift) & 1)
    for i, pidx in enumerate(indices):
        b0 = bits[i * 2]     if i * 2     < len(bits) else 0
        b1 = bits[i * 2 + 1] if i * 2 + 1 < len(bits) else 0
        img_flat[pidx, 0] = (int(img_flat[pidx, 0]) & 0xFC) | (b0 << 1) | b1


def _extract_bits(img_flat: np.ndarray, indices: np.ndarray, n_bytes: int) -> bytes:
    """Extract n_bytes from img_flat at positions given by indices."""
    bits = []
    for pidx in indices[:n_bytes * 4]:
        v = int(img_flat[pidx, 0]) & 0x03
        bits.append((v >> 1) & 1)
        bits.append(v & 1)
    out = bytearray()
    for i in range(0, n_bytes * 8, 8):
        byte = 0
        for j in range(8):
            byte = (byte << 1) | (bits[i + j] if i + j < len(bits) else 0)
        out.append(byte)
    return bytes(out)


def stego_encode(img_bgr: np.ndarray, plaintext: str):
    """
    Returns (modified_image, token_string).
    token = urlsafe_b64(salt)  — 24 ASCII chars, all the receiver needs.
    Payload layout in image: [SALT(16)] [LEN(4)] [FERNET_CIPHERTEXT]
    """
    salt       = secrets.token_bytes(SALT_BYTES)
    fernet_key = _derive_key(salt)
    ciphertext = Fernet(fernet_key).encrypt(plaintext.encode("utf-8"))
    payload    = salt + struct.pack(">I", len(ciphertext)) + ciphertext

    h, w = img_bgr.shape[:2]
    n_pixels = h * w
    if len(payload) * 4 > n_pixels:
        raise ValueError(
            f"Message too large: needs {len(payload)*4} pixels, "
            f"image only has {n_pixels}.")

    img_out  = img_bgr.copy()
    img_flat = img_out.reshape(-1, 3)
    _embed_bits(img_flat, payload, salt)

    token = base64.urlsafe_b64encode(salt).decode()
    return img_out, token


def stego_decode(img_bgr: np.ndarray, token: str) -> str:
    """
    Decode a message from img_bgr using the given token string.
    token = urlsafe_b64(salt)
    """
    try:
        salt = base64.urlsafe_b64decode(token.strip() + "==")
    except Exception:
        raise ValueError("Invalid key token — cannot base64-decode it.")
    if len(salt) != SALT_BYTES:
        raise ValueError(
            f"Invalid key token length: got {len(salt)} bytes, expected {SALT_BYTES}.")

    fernet_key = _derive_key(salt)
    h, w       = img_bgr.shape[:2]
    n_pixels   = h * w
    img_flat   = img_bgr.reshape(-1, 3)

    # ── Step 1: read header (salt + 4-byte length) ────────────────────────────
    header_size = SALT_BYTES + 4
    h_indices   = _scatter_indices(n_pixels, header_size * 4, salt)
    header      = _extract_bits(img_flat, h_indices, header_size)

    embedded_salt = header[:SALT_BYTES]
    if embedded_salt != salt:
        raise ValueError("Key mismatch — this key does not match the image.")

    ct_len = struct.unpack(">I", header[SALT_BYTES:SALT_BYTES + 4])[0]
    if ct_len == 0 or ct_len > n_pixels * 4:
        raise ValueError("Corrupted data — bad ciphertext length in header.")

    # ── Step 2: read full payload ─────────────────────────────────────────────
    total      = header_size + ct_len
    all_idx    = _scatter_indices(n_pixels, total * 4, salt)
    payload    = _extract_bits(img_flat, all_idx, total)
    ciphertext = payload[header_size:header_size + ct_len]

    try:
        return Fernet(fernet_key).decrypt(ciphertext).decode("utf-8")
    except Exception:
        raise ValueError("Decryption failed — wrong key or corrupted image.")


